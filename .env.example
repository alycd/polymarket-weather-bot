# Polymarket live trading credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your wallet private key (0x...)
POLYMARKET_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Proxy wallet address shown in Polymarket UI (the Safe/funder address)
POLYMARKET_PROXY_ADDRESS=0x_YOUR_PROXY_ADDRESS_HERE

# Signature type: 0 = EOA, 1 = Magic.link / embedded wallet
POLYMARKET_SIGNATURE_TYPE=1

# Generated by running: python scripts/gen_clob_creds.py
POLYMARKET_API_KEY=your-api-key-uuid
POLYMARKET_API_SECRET=your-api-secret
POLYMARKET_API_PASSPHRASE=your-api-passphrase

# Telegram notifications (optional — leave blank to disable)
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

[Unit]
Description=Polymarket Bot Web Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=aadichauhan
WorkingDirectory=/home/aadichauhan/polymarket_bot
ExecStart=/home/aadichauhan/polymarket_bot/venv/bin/python web_dashboard.py
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
